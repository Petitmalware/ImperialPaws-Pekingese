<div class="admin-shell">
  <%- include("../partials/admin-sidebar", { active: "admins" }) %>

  <main class="admin-content">
    <header class="admin-page-header">
      <div>
        <p class="admin-eyebrow">Access</p>
        <h1>Admins</h1>
        <p class="admin-subtitle">Owner-only access. Add administrators, reset passwords, and remove non-owner accounts.</p>
      </div>
    </header>

    <% if (typeof error !== "undefined" && error) { %>
      <div class="admin-alert error"><%= error %></div>
    <% } %>

    <% if (typeof success !== "undefined" && success) { %>
      <div class="admin-alert success"><%= success %></div>
    <% } %>

    <section class="admin-grid two">
      <div class="admin-card">
        <h2>Add New Admin</h2>
        <form method="POST" action="/admin/admins/add" class="admin-form">
          <div class="form-group">
            <label>Username</label>
            <input
              type="text"
              name="username"
              value="<%= values && values.username ? values.username : '' %>"
              autocomplete="username"
              required>
          </div>

          <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" minlength="8" autocomplete="new-password" required>
          </div>

          <button type="submit" class="btn-primary">Add Admin</button>
        </form>
      </div>

      <div class="admin-card">
        <h2>Admin Rules</h2>
        <p class="admin-muted">Admins can manage puppies, applications, testimonials, invoices, and settings.</p>
        <p class="admin-muted">Only accounts with the owner role can create, remove, or reset other admin accounts.</p>
      </div>
    </section>

    <section class="admin-card admin-section-gap">
      <div class="admin-section-title">
        <h2>Existing Admins</h2>
      </div>

      <% if (!admins || admins.length === 0) { %>
        <p class="admin-empty">No admins found.</p>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Username</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>

            <tbody>
              <% admins.forEach(admin => { %>
                <tr>
                  <td><%= admin.username %></td>
                  <td><%= admin.role %></td>
                  <td>
                    <span class="status-pill <%= admin.active ? 'approved' : 'rejected' %>">
                      <%= admin.active ? 'Active' : 'Inactive' %>
                    </span>
                  </td>
                  <td class="admin-actions">
                    <form method="POST" action="/admin/admins/<%= admin.id %>/password" class="status-form">
                      <input type="password" name="password" placeholder="New password" minlength="8" required>
                      <button type="submit">Update Password</button>
                    </form>

                    <% if (admin.role !== "owner") { %>
                      <form method="POST" action="/admin/admins/<%= admin.id %>/delete" onsubmit="return confirm('Remove this admin?');">
                        <button type="submit" class="btn-danger">Remove</button>
                      </form>
                    <% } else { %>
                      <span class="admin-muted">Owner</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </main>
</div>
